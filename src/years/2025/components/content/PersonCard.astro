---
import Icon from '@/years/2025/components/ui/Icon.astro';

interface Props {
  name: string;
  imageSrc?: string;
  linkedin?: string;
  personalWebsite?: string;
}

const { name, imageSrc, linkedin, personalWebsite } = Astro.props;
const initials = name
  .split(' ')
  .filter(Boolean)
  .map((part) => part[0])
  .join('')
  .slice(0, 3);
---

<div class="flex w-[200px] min-h-[200px] flex-col items-center">
  <div class="relative w-full overflow-hidden bg-slate-200">
    {imageSrc ? (
      <img src={imageSrc} alt={name} width="200" height="200" class="aspect-square w-full object-cover object-center" />
    ) : (
      <div class="grid aspect-square w-full place-items-center bg-gradient-to-br from-blue-200 to-purple-200 text-4xl font-semibold text-slate-500">
        {initials}
      </div>
    )}
  </div>

  <div class="flex w-full items-center justify-center gap-2 py-2 text-center">
    <h3 class="text-xl font-semibold text-gray-900">{name}</h3>
    {(linkedin || personalWebsite) && (
      <div class="flex items-center justify-center gap-2 text-sm text-slate-500">
        {linkedin && (
          <a
            href={linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 transition-colors hover:text-blue-800"
            aria-label={`LinkedIn profile of ${name}`}
          >
            <Icon name="linkedin" className="h-5 w-5" />
          </a>
        )}

        {personalWebsite && (
          <a
            href={personalWebsite}
            target="_blank"
            rel="noopener noreferrer"
            class="text-purple-600 transition-colors hover:text-purple-800"
            aria-label={`Personal website of ${name}`}
          >
            <Icon name="globe-alt" className="h-5 w-5" />
          </a>
        )}
      </div>
    )}
  </div>
</div>
