---
import type { SiteLocale } from '@/config/site';
import Icon from '@/years/2025/components/ui/Icon.astro';

interface Props {
  dialogId: string;
  locale?: SiteLocale;
  nameLines: readonly string[];
  logoSrc: string;
  logoAlt: string;
  href?: string;
  description?: string;
  logoClass?: string;
  nameClass?: string;
  descriptionClass?: string;
  cardClass?: string;
  showName?: boolean;
}

const {
  dialogId,
  locale = 'en',
  nameLines,
  logoSrc,
  logoAlt,
  href,
  description,
  logoClass = 'w-56 sm:w-80',
  nameClass = 'mt-4 text-base font-semibold sm:text-xl',
  descriptionClass = 'mt-2 text-sm text-gray-600 sm:text-base',
  cardClass = '',
  showName = true,
} = Astro.props;

const hasModal = Astro.slots.has('modal');
const officialWebsiteLabel = locale === 'zh-hk' ? '官方網站' : 'Official Website';
const closeDialogLabel = locale === 'zh-hk' ? '關閉視窗' : 'Close dialog';
---

<div class:list={['flex flex-col items-center justify-center', cardClass]}>
  {hasModal ? (
    <button
      type="button"
      class="cursor-pointer"
      onclick={`document.getElementById('${dialogId}')?.showModal()`}
    >
      <img src={logoSrc} alt={logoAlt} class:list={['aspect-square object-contain', logoClass]} />
    </button>
  ) : href ? (
    <a href={href} target="_blank" rel="noopener noreferrer" class="cursor-pointer">
      <img src={logoSrc} alt={logoAlt} class:list={['aspect-square object-contain', logoClass]} />
    </a>
  ) : (
    <img src={logoSrc} alt={logoAlt} class:list={['aspect-square object-contain', logoClass]} />
  )}

  {showName && (
    <span class:list={['w-full text-center text-gray-700', nameClass]}>
      {nameLines.map((line, index) => (
        <>
          {index > 0 && <br />}
          {line}
        </>
      ))}
    </span>
  )}

  {description && <p class:list={['w-full text-center text-wrap text-gray-500', descriptionClass]}>{description}</p>}

  {hasModal && (
    <dialog
      id={dialogId}
      class="fixed left-1/2 top-1/2 max-h-[92vh] w-[min(94vw,64rem)] max-w-[calc(100vw-1rem)] -translate-x-1/2 -translate-y-1/2 rounded-2xl border border-slate-200 bg-white p-0 text-sm text-gray-700 shadow-2xl backdrop:bg-slate-900/40 md:text-base"
      onclick="if (this === arguments[0]?.target) this.close()"
    >
      <div class="relative max-h-[92vh] overflow-y-auto overflow-x-clip p-4 sm:p-6 md:p-10">
        <form method="dialog">
          <button
            type="submit"
            class="absolute right-4 top-4 inline-flex cursor-pointer items-center justify-center text-slate-600 transition-colors hover:text-slate-900 sm:right-6 sm:top-6 md:right-8 md:top-8"
            aria-label={closeDialogLabel}
          >
            <Icon name="close" className="h-6 w-6" />
          </button>
        </form>

        <div class="flex flex-col items-center justify-center">
          <img src={logoSrc} alt={logoAlt} class="aspect-square w-24 rounded-xl object-contain md:w-36" />
          <h3 class="mt-2 text-center text-base font-bold md:text-xl">
            {nameLines.map((line, index) => (
              <>
                {index > 0 && <br />}
                {line}
              </>
            ))}
          </h3>
        </div>

        <div class="mt-6 space-y-4 px-1 pb-2 text-sm/7 sm:px-4 md:px-10 md:text-base/8">
          <slot name="modal" />
        </div>

        {href && (
          <div class="mt-6 mb-4 flex justify-center md:mb-6">
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-md bg-indigo-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/30 transition-colors hover:bg-indigo-600"
            >
              {officialWebsiteLabel}
            </a>
          </div>
        )}
      </div>
    </dialog>
  )}
</div>
