const content = resolveRequiredLocalizedValue(copy, locale);
const viewAllOutletsLabel = content.viewAllOutletsLabel.replace(/\s*->\s*$/, '');

const paymentMethods: PaymentMethod[] = [
  {
    name: {
      en: 'Credit Card',
      'zh-hk': '信用卡',
      'zh-hant': '信用卡',
      'zh-hans': '信用卡',
      ja: 'クレジットカード',
    },
    icon: 'credit-card',
  },
  {
    name: {
      en: 'Octopus',
      'zh-hk': '八達通',
      'zh-hant': '八達通',
      'zh-hans': '八达通',
      ja: 'Octopus',
    },
  },
  {
    name: {
      en: 'AlipayHK',
      'zh-hk': 'AlipayHK',
      'zh-hant': 'AlipayHK',
      'zh-hans': 'AlipayHK',
      ja: 'AlipayHK',
    },
    icon: 'alipay',
  },
  {
    name: {
      en: 'Apple Pay',
      'zh-hk': 'Apple Pay',
      'zh-hant': 'Apple Pay',
      'zh-hans': 'Apple Pay',
      ja: 'Apple Pay',
    },
    icon: 'apple',
  },
  {
    name: {
      en: 'WeChat Pay HK',
      'zh-hk': 'WeChat Pay HK',
      'zh-hant': 'WeChat Pay HK',
      'zh-hans': 'WeChat Pay HK',
      ja: 'WeChat Pay HK',
    },
    icon: 'wechat',
  },
  {
    name: {
      en: 'Cash',
      'zh-hk': '現金',
      'zh-hant': '現金',
      'zh-hans': '现金',
      ja: '現金',
    },
    icon: 'currency-dollar-circle',
  },
];

const pyNightAccess = [
  {
    label: content.speakersAccessLabel,
    detail: content.speakersAccessDetail,
  },
  {
    label: content.allAttendeesLabel,
    detail: content.allAttendeesDetail,
  },
] as const;
---

<div class="mx-auto max-w-4xl px-1 py-8 sm:px-2 md:px-4">
  <h1 class="mb-12 text-center text-xl font-bold leading-tight text-gray-700 sm:text-2xl md:text-3xl lg:text-4xl">
    {content.title}
  </h1>

  <div class="space-y-12">
    <section class="overflow-hidden rounded-lg bg-white shadow-md">
      <div class="p-4 sm:p-6 md:p-8">
        <h2 class="mb-4 flex items-center text-xl font-bold text-blue-700 md:text-2xl">
          <Icon name="utensils" className="mr-4 h-6 w-6 flex-shrink-0" />
          <span>{content.lunchHeading}</span>
        </h2>

        <p class="mb-6 text-sm text-gray-600 md:text-base lg:text-lg">
          {content.lunchDescription}
        </p>

        <div class="space-y-2 rounded-lg bg-gray-50 p-4 text-sm md:text-base">
          <p>
            <strong>{content.locationLabel}</strong> City Express at
            Yeung Kin Man Academic Building, 5/F
          </p>
          <p><strong>{content.openingHoursLabel}</strong> 07:00 - 21:00</p>
        </div>

        <div class="mt-4 rounded-r-lg border-l-4 border-yellow-400 bg-yellow-50 p-4 text-sm text-yellow-800 md:text-base">
          <h3 class="mb-2 flex items-center font-bold">
            <Icon name="information-circle-outline" className="mr-2 h-5 w-5 flex-shrink-0" />
            {content.paymentNoteHeading}
          </h3>
          <p>{content.paymentNote}</p>
        </div>

        <div class="mt-6">
          <h3 class="mb-3 text-sm font-semibold text-gray-700 md:text-base">
            {content.acceptedPaymentMethodsLabel}
          </h3>
          <div class="flex flex-wrap gap-2">
            {paymentMethods.map((method) => (
              <div class="flex items-center gap-2 rounded-full bg-gray-100 px-3 py-1.5 text-xs text-gray-700">
                {method.icon && <Icon name={method.icon} className="h-4 w-4" />}
                <span>{resolveRequiredLocalizedValue(method.name, locale)}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-6 text-center">
          <a
            href="https://www.cityu.edu.hk/en/directories/catering"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-blue-600 hover:underline"
          >
            <span>{viewAllOutletsLabel}</span>
            <Icon name="arrow-right" className="h-4 w-4 flex-shrink-0" />
          </a>
        </div>
      </div>
    </section>

    <section class="overflow-hidden rounded-lg bg-white shadow-md">
      <div class="p-4 sm:p-6 md:p-8">
        <h2 class="mb-4 flex items-center text-xl font-bold text-fuchsia-700 md:text-2xl">
          <Icon name="glass-cheers" className="mr-4 h-6 w-6 flex-shrink-0" />
          <span>{content.pyNightHeading}</span>
        </h2>

        <p class="mb-6 text-sm text-gray-600 md:text-base lg:text-lg">
          {content.pyNightDescription}
        </p>

        <div class="mt-6 border-l-4 border-fuchsia-500 pl-4">
          <h3 class="mb-2 text-base font-bold text-gray-800 md:text-lg">
            {content.joinPartyHeading}
          </h3>
          <p class="mb-4 text-sm md:text-base">
            {content.joinPartyDescription}
          </p>
          <div class="space-y-2 text-sm md:text-base">
            {pyNightAccess.map((item) => (
              <p>
                <strong>{item.label}:</strong> {item.detail}
              </p>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="overflow-hidden rounded-lg bg-white shadow-md">
      <div class="p-4 sm:p-6 md:p-8">
        <h2 class="mb-4 flex items-center text-xl font-bold text-amber-700 md:text-2xl">
          <Icon name="store" className="mr-4 h-6 w-6 flex-shrink-0" />
          <span>{content.selfFundedDinnerHeading}</span>
        </h2>

        <p class="mb-6 text-sm text-gray-600 md:text-base lg:text-lg">
          {content.selfFundedDinnerDescription}
        </p>

        <div class="rounded-lg bg-gray-50 p-4 text-center text-sm md:text-base">
          <p class="font-semibold text-gray-800">
            {content.headingToLabel}
          </p>
          <p class="my-1 text-lg font-bold text-amber-800">Ban Heung Lau (品香樓)</p>
          <p class="text-gray-600">{content.restaurantDescription}</p>
        </div>

        <div class="mt-6 flex justify-center text-sm md:text-base">
          <a
            href="https://maps.app.goo.gl/5Q4BdKbFn7GgaAY49"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md bg-amber-600 px-6 py-3 font-medium text-white shadow-md transition-colors duration-300 hover:bg-amber-700"
          >
            <Icon name="map-marked-alt" className="h-5 w-5 flex-shrink-0" />
            <span>{content.mapButtonLabel}</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</div>
