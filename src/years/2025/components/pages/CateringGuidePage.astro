---
import {
  type LocalizedValue,
  resolveRequiredLocalizedValue,
  type SiteLocale,
} from '@/config/site';
import Icon from '@/years/2025/components/ui/Icon.astro';

interface Props {
  locale: SiteLocale;
}

type PaymentIconName =
  | 'credit-card'
  | 'alipay'
  | 'apple'
  | 'wechat'
  | 'currency-dollar-circle';

interface PaymentMethod {
  name: LocalizedValue<string>;
  icon?: PaymentIconName;
}

const { locale } = Astro.props;

type CateringGuideCopy = {
  title: string;
  lunchHeading: string;
  lunchDescription: string;
  locationLabel: string;
  openingHoursLabel: string;
  paymentNoteHeading: string;
  paymentNote: string;
  acceptedPaymentMethodsLabel: string;
  viewAllOutletsLabel: string;
  pyNightHeading: string;
  pyNightDescription: string;
  joinPartyHeading: string;
  joinPartyDescription: string;
  selfFundedDinnerHeading: string;
  selfFundedDinnerDescription: string;
  headingToLabel: string;
  restaurantDescription: string;
  mapButtonLabel: string;
  speakersAccessLabel: string;
  speakersAccessDetail: string;
  allAttendeesLabel: string;
  allAttendeesDetail: string;
};

const copy: LocalizedValue<CateringGuideCopy> = {
