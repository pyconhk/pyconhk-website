---
import {
  type LocalizedValue,
  resolveLocalizedValue,
  resolveRequiredLocalizedValue,
  type SiteLocale,
  type SiteYear,
} from '@/config/site';
import {
  applySessionOverrides,
  fetchConferenceSchedule,
  formatScheduleDayLabel,
  formatScheduleSyncTime,
  formatScheduleTimeRange,
  getLanguageLabel,
  getPublishedSessionCount,
  hasPublishedSessions,
  type ScheduleSessionStatus,
} from '@/lib/schedule';
import Icon from '@/years/2025/components/ui/Icon.astro';
import { scheduleSessionOverrides } from '@/years/2025/data/schedule-overrides';

interface Props {
  year: SiteYear;
  locale: SiteLocale;
}

const { locale } = Astro.props;
const schedule = applySessionOverrides(
  await fetchConferenceSchedule(),
  scheduleSessionOverrides
);

