---
import {
  type LocalizedValue,
  resolveRequiredLocalizedValue,
  type SiteLocale,
  type SiteYear,
} from '@/config/site';
import { buildLocalizedPath } from '@/lib/routing';
import {
  getLocalizedText,
  getLocalizedTextList,
  getSprintLevelLabel,
  type SprintProject,
  sprintFacts,
  sprintProjects,
  sprintSchedule,
} from '@/years/2025/data/sprint';
import { callForSprintUrl } from '@/years/2025/external-links';

interface Props {
  year: SiteYear;
  locale: SiteLocale;
}

const { year, locale } = Astro.props;

