  discordDescription: string;
  testTitle: string;
  testDescription: string;
  testWarning: string;
  warningLabel: string;
  scheduleHeading: string;
  timeLabel: string;
  itemLabel: string;
  projectsHeading: string;
  projectBadge: string;
  leadLabel: string;
  githubLabel: string;
  discordLabel: string;
  goalsLabel: string;
  openBadge: string;
  submitProjects: string;
  faqBadge: string;
  qnaLabel: string;
