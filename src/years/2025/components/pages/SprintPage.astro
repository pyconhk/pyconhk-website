const content = resolveRequiredLocalizedValue(copy, locale);

function getProjectDescription(project: SprintProject): readonly string[] {
  return getLocalizedTextList(project.description, locale);
}

function getProjectGoals(project: SprintProject): readonly string[] {
  return getLocalizedTextList(project.goals, locale);
}

const sprintQnaHref = buildLocalizedPath(year, locale, 'sprint/qna');

function getFactClasses(tone: 'amber' | 'blue'): string[] {
  return tone === 'amber'
    ? ['bg-amber-50 text-amber-700 ring-amber-100']
    : ['bg-blue-50 text-blue-700 ring-blue-100'];
}

function getLevelClasses(level: SprintProject['level']): string[] {
  return level === 'all-levels'
    ? ['bg-blue-100 text-blue-700']
    : ['bg-yellow-100 text-yellow-700'];
}
---

<div class="mx-auto max-w-4xl">
  <h1 class="mb-8 text-center text-xl font-bold leading-tight text-gray-700 sm:text-2xl md:text-3xl lg:text-4xl">
    {content.title}
  </h1>

  <div class="mb-12 rounded-2xl border-l-4 border-amber-400 bg-amber-50 p-6 shadow-sm">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-700">
          {content.prepEyebrow}
        </p>
        <h2 class="mt-2 text-xl font-bold text-amber-800">{content.prepTitle}</h2>
      </div>
      <p class="max-w-2xl text-sm/relaxed text-amber-900/90 md:text-base/relaxed">
        {content.prepDescription}
      </p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <article class="rounded-xl bg-white/80 p-5 shadow-sm ring-1 ring-amber-100">
        <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-amber-700">
          01
        </span>
        <h3 class="mt-4 font-bold text-gray-800">{content.laptopTitle}</h3>
        <p class="mt-2 text-sm text-gray-700 md:text-base">{content.laptopDescription}</p>
      </article>

      <article class="rounded-xl bg-white/80 p-5 shadow-sm ring-1 ring-indigo-100 md:col-span-2">
        <span class="inline-flex rounded-full bg-indigo-100 px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-indigo-700">
          02
        </span>
        <h3 class="mt-4 font-bold text-gray-800">{content.discordTitle}</h3>
        <p class="mt-2 text-sm text-gray-700 md:text-base">{content.discordDescription}</p>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {sprintProjects.map((project) => (
            <div class="rounded-lg bg-slate-50 p-3 ring-1 ring-slate-200">
              <p class="text-sm font-medium text-slate-800">{project.title}</p>
              <a
                href={project.discordChannel}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 inline-block text-sm font-semibold text-blue-600 hover:underline"
              >
                #{project.discordChannelDisplay}
              </a>
            </div>
          ))}
        </div>
      </article>

      <article class="rounded-xl bg-white/80 p-5 shadow-sm ring-1 ring-rose-100 md:col-span-3">
        <span class="inline-flex rounded-full bg-rose-100 px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-rose-700">
          03
        </span>
        <h3 class="mt-4 font-bold text-gray-800">{content.testTitle}</h3>
        <p class="mt-2 text-sm text-gray-700 md:text-base">{content.testDescription}</p>
        <p class="mt-2 text-sm text-gray-700 md:text-base">
          <strong>{content.warningLabel}</strong>
          {' '}{content.testWarning}
        </p>
      </article>
    </div>
  </div>

  <div class="rounded-2xl bg-white p-4 shadow-md md:p-6">
    <div class="mt-2 grid gap-4 md:grid-cols-2">
      {sprintFacts.map((fact) => (
        <div class:list={['rounded-xl px-5 py-4 shadow-sm ring-1', ...getFactClasses(fact.tone)]}>
          <p class="text-xs font-bold uppercase tracking-[0.16em]">
            {getLocalizedText(fact.label, locale)}
          </p>
          <p class="mt-2 text-base font-semibold md:text-lg">
            {getLocalizedText(fact.value, locale)}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-4 md:mt-6">
      <h2 class="mb-4 text-xl font-bold text-gray-700">{content.scheduleHeading}</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full rounded-xl border border-gray-200 bg-white">
          <thead>
            <tr class="bg-gray-100">
              <th class="border-b px-4 py-2 text-left">{content.timeLabel}</th>
              <th class="border-b px-4 py-2 text-left">{content.itemLabel}</th>
            </tr>
          </thead>
          <tbody>
            {sprintSchedule.map((schedule, index) => (
              <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                <td class="border-b px-4 py-2">{schedule.startTime} - {schedule.endTime}</td>
                <td class="border-b px-4 py-2">{getLocalizedText(schedule.item, locale)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-700">{content.projectsHeading}</h2>

      {sprintProjects.map((project) => (
        <div class="mb-6 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md sm:p-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <span class:list={[
                  'rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.16em]',
                  ...getLevelClasses(project.level),
                ]}>
                  {getSprintLevelLabel(project.level, locale)}
                </span>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-slate-600">
                  {content.projectBadge}
                </span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-purple-600 md:text-xl">{project.title}</h3>
            </div>

            <div class="rounded-full bg-slate-50 px-4 py-2 text-sm text-slate-600 ring-1 ring-slate-200">
              <span class="font-medium">{content.leadLabel}:</span> {project.sprintLead}
            </div>
          </div>

          {getProjectDescription(project).length > 0 && (
            <div class="mt-4 space-y-4 text-sm/relaxed text-gray-700 md:text-base lg:text-lg">
              {getProjectDescription(project).map((paragraph) => <p>{paragraph}</p>)}
            </div>
          )}

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-200">
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-500">
                {content.githubLabel}
              </p>
              <a
                href={project.githubLink}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 inline-block break-all text-sm font-medium text-blue-600 hover:underline md:text-base"
              >
                {project.githubLinkDisplay}
              </a>
            </div>

            <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-200">
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-500">
                {content.discordLabel}
              </p>
              <a
                href={project.discordChannel}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 inline-block break-all text-sm font-medium text-blue-600 hover:underline md:text-base"
              >
                #{project.discordChannelDisplay}
              </a>
            </div>
          </div>

          <div class="mt-4 rounded-xl bg-purple-50 p-4 ring-1 ring-purple-100">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-purple-700">
              {content.goalsLabel}
            </p>
            <ul class="mt-3 list-disc pl-5 text-sm/relaxed text-gray-700 md:text-base lg:text-lg">
              {getProjectGoals(project).map((goal) => <li>{goal}</li>)}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-4 flex flex-col justify-center gap-4 md:mt-8 md:flex-row">
      <a
        href={callForSprintUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center rounded-md bg-purple-600 px-6 py-3 text-center font-medium text-white transition-colors duration-300 hover:bg-purple-700"
      >
        <span class="mr-2 rounded-full bg-white/15 px-2 py-0.5 text-xs font-bold uppercase tracking-[0.16em]">
          {content.openBadge}
        </span>
        {content.submitProjects}
      </a>

      <a
        href={sprintQnaHref}
        class="flex items-center justify-center rounded-md border-2 border-gray-300 bg-white px-6 py-3 text-center font-medium text-gray-700 transition-colors duration-300 hover:bg-gray-50"
      >
        <span class="mr-2 rounded-full bg-blue-50 px-2 py-0.5 text-xs font-bold uppercase tracking-[0.16em] text-blue-700">
          {content.faqBadge}
        </span>
        {content.qnaLabel}
      </a>
    </div>
  </div>
</div>
