function getLocalizedValue(value: LocalizedText | boolean | undefined, currentLocale: SiteLocale) {
  if (typeof value === 'boolean' || value === undefined) {
    return value;
  }

  return resolveLocalizedValue(value, currentLocale);
}

function getFeatureDisplay(
  key: SponsorshipFeatureKey,
  value: LocalizedText | boolean | undefined,
  currentLocale: SiteLocale
) {
  const localizedValue = getLocalizedValue(value, currentLocale);

  if (key === 'adDuringBreak' && typeof localizedValue === 'boolean') {
    return localizedValue
      ? { kind: 'text' as const, value: currentLocale === 'zh-hk' ? '有' : 'YES' }
      : { kind: 'icon' as const, icon: 'close' as const };
  }

  if (typeof localizedValue === 'boolean') {
    return {
      kind: 'icon' as const,
      icon: localizedValue ? ('check' as const) : ('close' as const),
    };
  }

  if (!localizedValue) {
    return { kind: 'icon' as const, icon: 'close' as const };
  }

  return { kind: 'text' as const, value: localizedValue };
}

function maxSlotsLabel(
  maxSlots: SponsorshipPlan['maxSlots'],
  currentLocale: SiteLocale
): string {
  if (currentLocale === 'zh-hk') {
    return maxSlots === 'unlimited' ? '名額不限' : `最多 ${maxSlots} 個名額`;
  }

  return maxSlots === 'unlimited'
    ? 'Unlimited slots'
    : `Max ${maxSlots} slot${maxSlots === 1 ? '' : 's'}`;
}
