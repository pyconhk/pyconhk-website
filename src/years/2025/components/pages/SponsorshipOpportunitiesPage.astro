<div>
  <h1 class="text-center text-2xl font-bold md:text-3xl lg:text-4xl">{content.title}</h1>

  <div class="mt-8 space-y-6">
    {content.introParagraphs.map((paragraph: string) => (
      <p>{paragraph}</p>
    ))}
  </div>

  <h2 class="mt-16 text-center text-2xl font-semibold md:text-3xl lg:text-4xl">
    {content.whySponsorTitle}
  </h2>
  <div class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-3">
    {sponsorBenefits.map((benefit) => (
      <div class="flex flex-col items-center rounded-lg px-6 text-center">
        <div class:list={['mt-4 rounded-full bg-gradient-to-br p-4', benefit.bgClass]}>
          <Icon name={benefit.icon} className={`h-12 w-12 ${benefit.iconClass}`} />
        </div>
        <h3 class="mt-4 text-lg font-semibold">{resolveRequiredLocalizedValue(benefit.title, locale)}</h3>
        <p class="mt-2 text-base text-gray-600">
          {resolveRequiredLocalizedValue(benefit.description, locale)}
        </p>
      </div>
    ))}
  </div>

  <div class="w-full py-12">
    <div class="container mx-auto px-0 lg:px-4">
      <div class="mb-12 text-center">
        <h2 class="mb-4 text-2xl font-bold text-gray-700 md:text-3xl lg:text-4xl">
          {content.plansTitle}
        </h2>
        <p class="mx-auto max-w-2xl text-gray-600">{content.plansDescription}</p>
      </div>

      <div class="relative" data-sponsorship-carousel>
        <div
          class="scrollbar-hide flex gap-6 overflow-x-auto overscroll-none pb-6 scroll-smooth snap-x snap-mandatory scroll-px-8"
          data-sponsorship-track
        >
          {sponsorshipPlans.map((plan) => (
            <div class="w-full flex-none snap-start p-1 lg:w-1/2 xl:w-1/3">
              <div
                class:list={[
                  'group relative mt-1 h-full overflow-hidden rounded-lg border-2 border-slate-300 bg-white shadow-md transition-all duration-300 hover:scale-95 hover:border-slate-600 hover:bg-slate-800 hover:shadow-xl',
                  plan.isPopular && 'ring-2 ring-brand-blue/50',
                ]}
              >
                {plan.isPopular && (
                  <div class="absolute right-2 top-2 z-10 rounded-full bg-brand-blue px-2 py-0.5 text-xs font-bold text-white">
                    {content.popularLabel}
                  </div>
                )}

                <div class:list={['relative h-16 bg-gradient-to-br', tierColors[plan.tier]]}>
                  <div class="relative z-10 p-3 text-white">
                    <h3 class="mb-0.5 text-lg font-bold">
                      {resolveRequiredLocalizedValue(plan.name, locale)}
                    </h3>
                    <p class="text-xs font-semibold opacity-90">
                      {content.sponsorshipFeeLabel}: {plan.fee}
                    </p>
                  </div>
                </div>

                <div class="bg-white p-3 transition-colors duration-300 group-hover:bg-slate-800">
                  <div
                    class:list={[
                      'mb-2 inline-block rounded-full px-2 py-0.5 text-xs font-semibold',
                      tierAccents[plan.tier],
                    ]}
                  >
                    {maxSlotsLabel(plan.maxSlots, locale)}
                  </div>

                  <div class="space-y-0.5 text-xs">
                    {featureSections.map((section) => (
                      <div>
                        <h4 class="mb-1 font-bold text-gray-800 transition-colors duration-300 group-hover:text-white">
                          {content[section.heading]}
                        </h4>

                        {section.items.map((feature) => {
                          const rawValue = plan.features[feature.key];
                          const display = getFeatureDisplay(feature.key, rawValue, locale);
                          const isHighlight = Boolean(feature.highlight && rawValue);

                          return (
