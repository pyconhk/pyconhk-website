                              class:list={[
                                'flex items-center justify-between rounded px-1 py-0.5 text-xs transition-colors duration-300',
                                isHighlight &&
                                  'border-l-2 border-brand-blue bg-brand-blue-soft group-hover:bg-brand-blue-dark',
                              ]}
                            >
                              <span class="font-medium text-gray-700 transition-colors duration-300 group-hover:text-white">
                                {resolveRequiredLocalizedValue(featureLabels[feature.key], locale)}
                              </span>

                              {display.kind === 'text' ? (
                                <span
                                  class:list={[
                                    'font-semibold transition-colors duration-300',
                                    isHighlight
                                      ? 'text-brand-blue group-hover:text-brand-blue-soft-strong'
                                      : 'text-gray-900 group-hover:text-white',
                                  ]}
                                >
                                  {display.value}
                                </span>
                              ) : (
                                <span class="inline-flex items-center justify-center">
                                  <Icon
                                    name={display.icon}
                                    className={
                                      display.icon === 'check'
                                        ? isHighlight
                                          ? 'h-4 w-4 text-brand-blue group-hover:text-brand-blue-soft-strong'
                                          : 'h-4 w-4 text-green-600 group-hover:text-green-400'
                                        : 'h-4 w-4 text-red-500 group-hover:text-rose-400'
                                    }
                                  />
                                </span>
                              )}
                            </div>
                          );
                        })}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 flex justify-center gap-8">
          <button
            type="button"
            class="flex items-center justify-center rounded-full bg-gray-200 p-4 text-slate-600 transition-colors hover:bg-gray-300"
            data-sponsorship-scroll="prev"
            aria-label={
              locale === 'zh-hk'
                ? '上一組方案'
                : locale === 'ja'
                  ? '前のカード'
                  : 'Previous cards'
            }
          >
            <Icon name="chevron-left" className="h-4 w-4" />
          </button>
          <button
            type="button"
            class="flex items-center justify-center rounded-full bg-gray-200 p-4 text-slate-600 transition-colors hover:bg-gray-300"
            data-sponsorship-scroll="next"
            aria-label={
              locale === 'zh-hk'
                ? '下一組方案'
                : locale === 'ja'
                  ? '次のカード'
                  : 'Next cards'
            }
          >
            <Icon name="chevron-right" className="h-4 w-4" />
          </button>
        </div>
      </div>
    </div>
  </div>

  <style>
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
  </style>

  <script is:inline data-astro-rerun>
    const carousels = document.querySelectorAll('[data-sponsorship-carousel]');

    for (const carousel of carousels) {
      const track = carousel.querySelector('[data-sponsorship-track]');

      if (!(track instanceof HTMLElement)) {
        continue;
      }

      const buttons = carousel.querySelectorAll('[data-sponsorship-scroll]');

      for (const button of buttons) {
        button.addEventListener('click', () => {
          const direction = button.getAttribute('data-sponsorship-scroll');
          const scrollAmount = track.clientWidth + 24;

          track.scrollBy({
            left: direction === 'prev' ? -scrollAmount : scrollAmount,
            behavior: 'smooth',
          });
        });
      }
    }
  </script>

  <div class="mt-2 text-center lg:mt-6">
    <div class="rounded-2xl bg-gradient-to-r from-brand-blue to-brand-yellow p-8">
      <h2 class="text-3xl font-bold xl:text-4xl">{content.ctaTitle}</h2>
      <p class="mt-8 text-lg opacity-90">{content.ctaDescription}</p>
      <div class="mt-6">
        <a
          href={callForSponsorshipsUrl}
          class="inline-block rounded-lg bg-white px-8 py-3 font-semibold text-brand-blue transition-colors hover:bg-slate-200"
          target="_blank"
          rel="noopener noreferrer"
        >
          {content.ctaButtonLabel}
        </a>
      </div>
    </div>
  </div>
</div>
