---
import { resolveRequiredLocalizedValue, type SiteLocale, type SiteYear } from '@/config/site';
import { buildLocalizedPath } from '@/lib/routing';
import Icon from '@/years/2025/components/ui/Icon.astro';
import { navigationItems } from '@/years/2025/data/navigation';
import type { SiteSectionSlug } from '@/years/2025/data/sections';

interface Props {
  year: SiteYear;
  locale: SiteLocale;
  currentSection?: SiteSectionSlug;
  mobile?: boolean;
}

const { year, locale, currentSection, mobile = false } = Astro.props;

type ResolvedNavigationLink = {
  kind: 'link';
  label: string;
  href: string;
  active: boolean;
};

type ResolvedNavigationGroup = {
  kind: 'group';
  label: string;
  active: boolean;
  children: ResolvedNavigationLink[];
};

type ResolvedNavigationItem = ResolvedNavigationLink | ResolvedNavigationGroup;

const resolvedNavigationItems: ResolvedNavigationItem[] = navigationItems.map((item) => {
  if (item.kind === 'group') {
    const children = item.children.map((child) => ({
      kind: 'link' as const,
      label: resolveRequiredLocalizedValue(child.label, locale),
      href: buildLocalizedPath(year, locale, child.path),
      active: child.activeSection === currentSection,
    }));

    return {
      kind: 'group' as const,
      label: resolveRequiredLocalizedValue(item.label, locale),
      active: children.some((child) => child.active),
      children,
    };
  }

  return {
    kind: 'link' as const,
    label: resolveRequiredLocalizedValue(item.label, locale),
    href: buildLocalizedPath(year, locale, item.path),
    active: item.activeSection === currentSection,
  };
});

const desktopLinkClass =
  "relative inline-flex items-center px-1 py-2.5 text-[0.95rem] font-semibold text-slate-600 transition-colors duration-200 hover:text-slate-800 xl:text-base after:absolute after:left-1/2 after:-bottom-1 after:h-0.5 after:w-0 after:-translate-x-1/2 after:bg-current after:transition-all after:duration-300 hover:after:w-full";

const desktopActiveClass = 'text-slate-800 after:w-full';
const dropdownPanelClass =
  'absolute left-0 top-full z-20 hidden min-w-[15rem] rounded-xl border border-slate-200 bg-white p-2 shadow-lg group-hover:block group-focus-within:block';
const mobileLinkClass =
  'relative block py-1.5 text-base font-normal leading-snug text-white transition-colors hover:text-white/80';
---

<ul class:list={[mobile ? 'flex flex-col gap-3' : 'flex items-center space-x-6 xl:space-x-7', 'm-0 list-none p-0']}>
  {resolvedNavigationItems.map((item) =>
    item.kind === 'group' ? (
      <li class:list={mobile ? 'mt-2' : 'group relative'}>
        {mobile ? (
          <>
            <div class="flex items-center justify-start gap-2 text-white">
              <span class:list={['text-base font-semibold leading-snug', item.active ? 'text-white' : 'text-white/80']}>
                {item.label}
              </span>
              <Icon name="chevron-down" className="h-3.5 w-3.5 text-current" />
            </div>

            <div class="mt-3 ml-2 border-l border-slate-600 pl-6">
              <ul class="m-0 list-none space-y-3 p-0">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[mobileLinkClass, child.active ? 'text-white' : 'text-white/80']}
                      data-mobile-nav-link="true"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </>
        ) : (
          <>
            <button
              type="button"
              class:list={[desktopLinkClass, item.active && desktopActiveClass]}
              aria-haspopup="true"
            >
              <span class="inline-flex items-center gap-1.5">
                <span>{item.label}</span>
                <Icon
                  name="chevron-down"
                  className="h-3.5 w-3.5 text-current transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
                />
              </span>
            </button>

            <div class="absolute left-0 top-full hidden h-3 w-full bg-transparent group-hover:block group-focus-within:block"></div>

            <div class={dropdownPanelClass}>
              <ul class="m-0 list-none space-y-1 p-0">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        'block rounded-lg px-3 py-2.5 text-[0.95rem] font-medium text-slate-600 transition-colors hover:bg-gray-100 hover:text-slate-800 xl:text-base',
                        child.active && 'bg-gray-100 text-slate-800',
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </>
        )}
      </li>
    ) : (
      <li class:list={mobile ? 'mt-2' : ''}>
        <a
          href={item.href}
          class:list={
            mobile
              ? [mobileLinkClass, item.active ? 'text-white' : 'text-white/80']
              : [desktopLinkClass, item.active && desktopActiveClass]
          }
          data-mobile-nav-link={mobile ? 'true' : undefined}
        >
          {item.label}
        </a>
      </li>
    )
  )}
</ul>
