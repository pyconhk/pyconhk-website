---
import type { SiteLocale, SiteYear } from '@/config/site';
import type { NewsSummary } from '@/lib/news';
import { buildLocalizedPath } from '@/lib/routing';
import NewsCard from '@/years/2025/components/news/NewsCard.astro';
import { getTranslations } from '@/years/2025/i18n';

interface Props {
  year: SiteYear;
  locale: SiteLocale;
  posts: NewsSummary[];
}

const { year, locale, posts } = Astro.props;
const t = getTranslations(locale, 'home');
const newsIndexHref = buildLocalizedPath(year, locale, 'news');
---

<div class="container mx-auto max-w-6xl px-4">
  <h2 class="mb-12 pb-2 text-center text-3xl font-bold text-slate-600 sm:text-4xl md:text-5xl">
    {t('newsHeading')}
  </h2>

  {
    posts.length > 0 ? (
      <ul class="space-y-4">
        {posts.map((post) => (
          <li class="border-b border-gray-200 pb-4">
            <NewsCard
              compact
              post={post}
              locale={locale}
              href={buildLocalizedPath(year, locale, `news/${post.slug}`)}
            />
          </li>
        ))}
      </ul>
    ) : (
        <p class="text-gray-500">{t('newsEmptyState')}</p>
      )
  }

  {
    posts.length > 0 && (
      <div class="mt-6 text-center">
        <a href={newsIndexHref} class="font-semibold text-blue-600 hover:underline">
          {t('viewAllNewsLabel')}
          <span class="ml-1" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    )
  }
</div>
