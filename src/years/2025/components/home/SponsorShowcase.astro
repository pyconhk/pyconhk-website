---
import type { SiteLocale, SiteYear } from '@/config/site';
import { featuredSponsors } from '@/years/2025/data/sponsors';

interface Props {
  year: SiteYear;
  locale: SiteLocale;
}

const slideWidthPx = 200;
const extendedSponsors = [...featuredSponsors, ...featuredSponsors];
const trackWidth = extendedSponsors.length * slideWidthPx;
---

<div class="container mx-auto px-4">
  <div class="relative w-full overflow-hidden py-10">
    <div class="animate-scroll flex" style={`width: ${trackWidth}px;`}>
      {extendedSponsors.map((sponsor) => (
        <div class="flex h-[60px] w-[200px] items-center justify-center px-6">
          <a href={sponsor.url} target="_blank" rel="noopener noreferrer" class="cursor-pointer">
            <img
              src={sponsor.imagePath}
              alt={sponsor.name}
              width="150"
              height="60"
              loading="lazy"
              class="h-full w-auto object-contain grayscale transition-all duration-300 hover:grayscale-0"
            />
          </a>
        </div>
      ))}
    </div>
  </div>
</div>
