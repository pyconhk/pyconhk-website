---
import { type SiteLocale, type SiteYear, siteName } from '@/config/site';
import { getLatestPosts } from '@/lib/news';
import ActionShowcase from '@/years/2025/components/home/ActionShowcase.astro';
import HomeHero from '@/years/2025/components/home/HomeHero.astro';
import LatestNewsTeaser from '@/years/2025/components/home/LatestNewsTeaser.astro';
import SpeakerShowcase from '@/years/2025/components/home/SpeakerShowcase.astro';
import SponsorShowcase from '@/years/2025/components/home/SponsorShowcase.astro';
import { getTranslations } from '@/years/2025/i18n';
import ConferenceLayout from '@/years/2025/layouts/ConferenceLayout.astro';

interface Props {
  year: SiteYear;
  locale: SiteLocale;
}

const { year, locale } = Astro.props;
const t = getTranslations(locale, 'home');
const latestPosts = await getLatestPosts(3, year, locale);
---

<ConferenceLayout title={`${siteName} ${year}`} description={t('intro')} year={year} locale={locale}>
  <div class="min-h-screen w-full -mt-20">
    <HomeHero year={year} locale={locale} />
    <section id="latest-news" class="scroll-mt-20 bg-gradient-to-b from-white to-blue-50 px-4 py-12 pt-24 md:py-18 md:pt-36">
      <LatestNewsTeaser year={year} locale={locale} posts={latestPosts} />
    </section>
    <section class="bg-gradient-to-b from-blue-50 to-white px-4 py-12 md:py-18">
      <SponsorShowcase year={year} locale={locale} />
    </section>
    <section class="bg-gradient-to-b from-white to-blue-50 px-4 py-12 md:py-18">
      <SpeakerShowcase locale={locale} />
    </section>
    <section class="bg-gradient-to-b from-blue-50 to-white px-4 py-12 md:py-18">
      <ActionShowcase year={year} locale={locale} />
    </section>
  </div>
</ConferenceLayout>
