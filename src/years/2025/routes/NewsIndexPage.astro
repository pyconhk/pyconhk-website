---
import { type SiteLocale, type SiteYear, siteName } from '@/config/site';
import { getPublishedPosts } from '@/lib/news';
import { buildLocalizedPath } from '@/lib/routing';
import NewsCard from '@/years/2025/components/news/NewsCard.astro';
import { getTranslations } from '@/years/2025/i18n';
import ConferenceLayout from '@/years/2025/layouts/ConferenceLayout.astro';

interface Props {
  year: SiteYear;
  locale: SiteLocale;
}

const { year, locale } = Astro.props;
const t = getTranslations(locale, 'home');
const posts = await getPublishedPosts(year, locale);
const pageHeading = locale === 'en' ? 'News' : t('newsHeading');
---

<ConferenceLayout
  title={`News | ${siteName} ${year}`}
  description={t('newsIntro')}
  year={year}
  locale={locale}
  currentSection="news"
>
  <section class="-mt-20 min-h-[calc(100vh-200px)] w-full bg-[url('/2025/inner-pages/background.svg')] bg-cover bg-center bg-no-repeat text-sm text-slate-500 md:text-base">
    <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
      <div class="relative mt-20 rounded-xl bg-slate-100/90 px-4 py-12 text-base/8 text-gray-700 shadow-xl md:px-12 md:py-16 md:text-lg/8 lg:px-16 lg:py-24">
        <h1 class="mb-8 text-center text-2xl font-bold text-gray-700 md:text-3xl lg:text-4xl">
          {pageHeading}
        </h1>

        {
          posts.length > 0 ? (
            <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
              {posts.map((post) => (
                <NewsCard
                  post={post}
                  locale={locale}
                  href={buildLocalizedPath(year, locale, `news/${post.slug}`)}
                />
              ))}
            </div>
          ) : (
            <p class="text-gray-500">{t('newsEmptyState')}</p>
          )
        }
      </div>
    </div>
  </section>
</ConferenceLayout>
