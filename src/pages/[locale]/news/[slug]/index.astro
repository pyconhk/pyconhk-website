---
import { locales } from '@/config/site';
import { getPublishedPostSlugs } from '@/lib/news';
import { resolveLocaleParam } from '@/lib/routing';
import NewsArticlePage from '@/years/2025/routes/NewsArticlePage.astro';
import { conferenceYear } from '@/years/2025/site';

export async function getStaticPaths() {
  const slugs = await getPublishedPostSlugs(conferenceYear);

  return locales.flatMap((locale) =>
    slugs.map((slug) => ({
      params: {
        locale: locale.code,
        slug,
      },
    }))
  );
}

const locale = resolveLocaleParam(Astro.params.locale);
const slug = Astro.params.slug || '';
---

<NewsArticlePage year={conferenceYear} locale={locale} slug={slug} />
